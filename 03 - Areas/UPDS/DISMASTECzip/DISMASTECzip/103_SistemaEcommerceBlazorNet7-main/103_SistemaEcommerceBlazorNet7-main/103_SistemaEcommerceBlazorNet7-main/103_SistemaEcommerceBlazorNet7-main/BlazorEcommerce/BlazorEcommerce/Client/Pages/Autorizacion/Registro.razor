@page "/registrarse"
@layout LoginLayout

@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IPersonaServicio _personaServicio
@inject NavigationManager _navServicio
@inject IToastService toastService
@inject IJSRuntime JSRuntime

<div class="container register-container">
    <div class="row justify-content-end">
        <div class="col-auto">
            <a href="/login" class="btn btn-outline-light">
                <i class="oi oi-arrow-left me-1"></i> Volver al inicio de sesión
            </a>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card rounded-lg mt-4 register-card">
                <div class="card-header register-header">
                    <h3 class="text-center font-weight-light my-3">
                        <span class="register-title-red">Crear </span><span class="register-title-black">Cuenta</span>
                    </h3>

                    <!-- Indicador de paso actual -->
                    <div class="progress">
                        <div class="progress-bar" role="progressbar"
                             style="width: @(pasoActual * 33)%"
                             aria-valuenow="@(pasoActual * 33)" aria-valuemin="0" aria-valuemax="100">
                            Paso @pasoActual de 3
                        </div>
                    </div>
                </div>
                <div class="card-body register-body">
                    <EditForm Model="modelo" OnValidSubmit="GuardarCambios">
                        <DataAnnotationsValidator />

                        @if (pasoActual == 1)
                        {
                            <!-- PASO 1: DATOS PERSONALES -->
                            <h4><i class="oi oi-person me-2"></i>Información Personal</h4>
                            <p class="register-subtitle">Complete sus datos de identificación para comenzar el proceso de registro.</p>

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputNombre" type="text" placeholder="Nombre"
                                               @bind-value="modelo.Nombre" required />
                                        <label for="inputNombre">Nombre*</label>
                                        <ValidationMessage For="@(() => modelo.Nombre)" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputApellidoPaterno" type="text" placeholder="Apellido Paterno"
                                               @bind-value="modelo.ApellidoPaterno" required />
                                        <label for="inputApellidoPaterno">Apellido Paterno*</label>
                                        <ValidationMessage For="@(() => modelo.ApellidoPaterno)" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputApellidoMaterno" type="text" placeholder="Apellido Materno"
                                               @bind-value="modelo.ApellidoMaterno" required />
                                        <label for="inputApellidoMaterno">Apellido Materno*</label>
                                        <ValidationMessage For="@(() => modelo.ApellidoMaterno)" />
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <div class="form-floating mb-3">
                                        <select class="form-select" id="inputTipoDocumento" @bind="modelo.TipoDocumento" required>
                                            <option value="">Seleccione...</option>
                                            <option value="CI">Carnet de Identidad</option>
                                            <option value="Pasaporte">Pasaporte Extranjero</option>
                                        </select>
                                        <label for="inputTipoDocumento">Tipo de Documento*</label>
                                        <ValidationMessage For="@(() => modelo.TipoDocumento)" />
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputNumeroDocumento" type="text"
                                               placeholder="Número de Documento" @bind-value="modelo.NumeroDocumento" required />
                                        <label for="inputNumeroDocumento">Número de Documento*</label>
                                        <small class="form-text text-muted">No incluir la extensión de su carnet (SC, LP, CB, etc)</small>
                                        <ValidationMessage For="@(() => modelo.NumeroDocumento)" />
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputFechaNacimiento" type="date"
                                               @bind-value="modelo.FechaNacimiento" required />
                                        <label for="inputFechaNacimiento">Fecha de Nacimiento*</label>
                                        <ValidationMessage For="@(() => modelo.FechaNacimiento)" />
                                    </div>
                                </div>
                                <!-- Inicio de la sección modificada para el teléfono -->
                                <div class="col-md-6">
                                    <div class="input-group mb-3">
                                        <div class="form-floating" style="width: 40%;">
                                            <select class="form-select" id="inputPrefijoPais" @bind-value="prefijoPais" @bind-value:event="oninput">
                                                @foreach (var prefijo in prefijosPaises)
                                                {
                                                    <option value="@prefijo">@prefijo</option>
                                                }
                                            </select>
                                            <label for="inputPrefijoPais">Prefijo*</label>
                                        </div>
                                        <div class="form-floating" style="width: 60%;">
                                            <input class="form-control register-input" id="inputTelefono" type="tel"
                                                   placeholder="Teléfono/Celular" @bind-value="modelo.Telefono" @bind-value:event="oninput" required />
                                            <label for="inputTelefono">Teléfono*</label>
                                        </div>
                                    </div>
                                    <ValidationMessage For="@(() => modelo.Telefono)" />
                                </div>
                                <!-- Fin de la sección modificada para el teléfono -->
                            </div>

                            <div class="form-floating mb-4">
                                <input class="form-control register-input" id="inputCorreo" type="email"
                                       placeholder="Correo Electrónico" @bind-value="modelo.Correo" required />
                                <label for="inputCorreo">Correo Electrónico*</label>
                                <ValidationMessage For="@(() => modelo.Correo)" />
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputPassword" type="password"
                                               placeholder="Contraseña" @bind-value="modelo.Clave" required />
                                        <label for="inputPassword">Contraseña*</label>
                                        <ValidationMessage For="@(() => modelo.Clave)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputConfirmPassword" type="password"
                                               placeholder="Confirmar Contraseña" @bind-value="modelo.ConfirmarClave" required />
                                        <label for="inputConfirmPassword">Confirmar Contraseña*</label>
                                        <ValidationMessage For="@(() => modelo.ConfirmarClave)" />
                                    </div>
                                </div>
                            </div>
                        }
                        else if (pasoActual == 2)
                        {
                            <!-- PASO 2: DIRECCIÓN -->
                            <h4><i class="oi oi-home me-2"></i>Información de Dirección</h4>
                            <p class="register-subtitle">Indique su dirección de residencia para poder brindarle un mejor servicio.</p>

                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <!-- Inicio del campo modificado para la dirección con mapa -->
                                    <div class="mb-3">
                                        <label for="inputDireccion">Dirección Completa*</label>
                                        <div class="input-group">
                                            <input class="form-control register-input" id="inputDireccion" type="text"
                                                   placeholder="Dirección" @bind-value="modelo.Direccion" readonly required />
                                            <button type="button" class="btn map-button" @onclick="AbrirMapaSeleccionDireccion">
                                                <i class="oi oi-map-marker me-1"></i> Seleccionar en el mapa
                                            </button>
                                        </div>
                                        <ValidationMessage For="@(() => modelo.Direccion)" />
                                    </div>
                                    <!-- Fin del campo modificado para la dirección con mapa -->
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputCiudad" type="text"
                                               placeholder="Ciudad" @bind-value="modelo.Ciudad" required />
                                        <label for="inputCiudad">Ciudad*</label>
                                        <ValidationMessage For="@(() => modelo.Ciudad)" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        <select class="form-select" id="inputPais" @bind="modelo.Pais" required>
                                            <option value="">Seleccione...</option>
                                            <option value="Bolivia">Bolivia</option>
                                            <option value="Argentina">Argentina</option>
                                            <option value="Brasil">Brasil</option>
                                            <option value="Chile">Chile</option>
                                            <option value="Colombia">Colombia</option>
                                            <option value="Ecuador">Ecuador</option>
                                            <option value="Paraguay">Paraguay</option>
                                            <option value="Perú">Perú</option>
                                            <option value="Uruguay">Uruguay</option>
                                            <option value="Venezuela">Venezuela</option>
                                            <option value="Otro">Otro</option>
                                        </select>
                                        <label for="inputPais">País*</label>
                                        <ValidationMessage For="@(() => modelo.Pais)" />
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <div class="form-floating mb-3">
                                        <input class="form-control register-input" id="inputCodigoPostal" type="text"
                                               placeholder="Código Postal" @bind-value="modelo.CodigoPostal" />
                                        <label for="inputCodigoPostal">Código Postal</label>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="form-floating mb-3">
                                        <textarea class="form-control register-input" id="inputReferencias" style="height: 100px"
                                                  placeholder="Referencias" @bind="modelo.Referencias"></textarea>
                                        <label for="inputReferencias">Referencias (cómo llegar, puntos de referencia)</label>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (pasoActual == 3)
                        {
                            <!-- PASO 3: FOTOS -->
                            <h4><i class="oi oi-camera-slr me-2"></i>Fotografía de Perfil</h4>
                            <p class="register-subtitle">
                                Suba una foto para su perfil. Si desea utilizar el inicio de sesión con reconocimiento facial,
                                active la opción correspondiente.
                            </p>

                            <div class="form-check mb-4">
                                <input class="form-check-input" type="checkbox"
                                       id="chkUseFacial" @bind="modelo.UseFacialRecognition" />
                                <label class="form-check-label" for="chkUseFacial">
                                    Habilitar reconocimiento facial para iniciar sesión
                                </label>
                                <small class="form-text text-muted d-block">
                                    Activando esta opción, podrá iniciar sesión utilizando su rostro en lugar de contraseña.
                                </small>
                            </div>

                            @if (modelo.UseFacialRecognition && string.IsNullOrEmpty(modelo.FacialImage) &&
                           !string.IsNullOrEmpty(modelo.Imagen))
                            {
                                <!-- Copiar la imagen de perfil como imagen facial -->
                                <div class="mt-3 mb-4">
                                    <button type="button" class="btn btn-info" @onclick="UsarImagenPerfilParaFacial">
                                        <i class="oi oi-camera-slr me-1"></i> Usar foto de perfil para reconocimiento facial
                                    </button>
                                </div>
                            }

                            <div class="row mb-4 justify-content-center">
                                <div class="col-md-6">
                                    <div class="card photo-card">
                                        <div class="card-header photo-card-header">
                                            <h5 class="photo-card-title">Foto de Perfil</h5>
                                        </div>
                                        <div class="card-body text-center p-4">
                                            @if (!string.IsNullOrEmpty(modelo.Imagen))
                                            {
                                                <div class="mb-3">
                                                    <img src="@modelo.Imagen" class="img-fluid rounded"
                                                         style="max-height: 240px; border: 3px solid var(--color-primary);"
                                                         alt="Foto de perfil" />
                                                </div>
                                                <button type="button" class="btn btn-outline-danger" @onclick="LimpiarImagen">
                                                    <i class="oi oi-trash me-1"></i> Quitar
                                                </button>
                                            }
                                            else
                                            {
                                                <div class="placeholder-image d-flex justify-content-center align-items-center mb-3"
                                                     style="height: 240px;">
                                                    <div class="text-center">
                                                        <i class="oi oi-camera-slr" style="font-size: 48px;"></i>
                                                        <p class="mt-2">Foto de Perfil</p>
                                                    </div>
                                                </div>
                                                <div class="mb-3">
                                                    <div class="input-group">
                                                        <InputFile class="form-control" accept="image/png, image/jpeg, image/gif" OnChange="OnFileChange" />
                                                        <button type="button" class="btn camera-button" @onclick="ActivarCamara">
                                                            <i class="oi oi-camera-slr"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-4 mb-3">
                            @if (pasoActual > 1)
                            {
                                <button type="button" class="btn btn-register-nav" @onclick="PasoAnterior">
                                    <i class="oi oi-chevron-left"></i> Anterior
                                </button>
                            }
                            else
                            {
                                <div></div> <!-- Espaciador -->
                            }

                            @if (pasoActual < 3)
                            {
                                <button type="button" class="btn btn-register-next" @onclick="SiguientePaso">
                                    Siguiente <i class="oi oi-chevron-right"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-register-submit" type="submit">
                                    <i class="oi oi-check me-1"></i> Completar Registro
                                </button>
                            }
                        </div>
                    </EditForm>
                </div>
                <div class="card-footer register-footer text-center py-3">
                    <div class="small">
                        <a href="/login" class="login-link">
                            <span class="register-red">¿Ya tienes una</span> <span class="register-black">cuenta? ¡Inicia sesión!</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para la cámara -->
<div class="modal fade register-modal @(mostrarModalCamara ? "show" : "")"
     id="camaraModal"
     style="display: @(mostrarModalCamara ? "block" : "none")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@tituloModalCamara</h5>
                <button type="button" class="btn-close" @onclick="CerrarModalCamara"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12 text-center">
                        <video id="video" style="max-width:100%; height:auto; border:2px solid var(--color-primary); border-radius:8px;" autoplay></video>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 text-center">
                        <canvas id="canvas" style="display:none;"></canvas>
                        <img id="capturedImage" class="img-fluid" style="max-height:200px; display:none; border:2px solid var(--color-primary); border-radius:8px;" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CerrarModalCamara">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnCapturar" @onclick="TomarFoto">
                    <i class="oi oi-camera-slr me-1"></i> Capturar Foto
                </button>
                <button type="button" class="btn btn-success" id="btnGuardar" style="display:none;" @onclick="GuardarFoto">
                    <i class="oi oi-check me-1"></i> Usar esta foto
                </button>
                <button type="button" class="btn btn-warning" id="btnReintentar" style="display:none;" @onclick="ReintentarFoto">
                    <i class="oi oi-action-redo me-1"></i> Reintentar
                </button>
            </div>
        </div>
    </div>
    @if (mostrarModalCamara)
    {
        <!-- Usar una implementación personalizada del backdrop -->
        <div class="modal-backdrop show" style="pointer-events: none;"></div>
    }
</div>

<!-- Modal para selección de dirección con Leaflet y OpenStreetMap -->
<div class="modal fade register-modal @(mostrarModalMapa ? "show" : "")" id="mapaModal" tabindex="-1" role="dialog"
     style="display: @(mostrarModalMapa ? "block" : "none")">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="oi oi-map-marker me-2"></i>Selecciona tu ubicación</h5>
                <button type="button" class="btn-close" @onclick="CerrarModalMapa"></button>
            </div>
            <div class="modal-body">
                <!-- Barra de búsqueda para OpenStreetMap -->
                <div class="input-group mb-3 map-search-group">
                    <input type="text" class="form-control" id="map-search-input" placeholder="Buscar dirección...">
                    <button class="btn map-search-button" type="button" id="btn-buscar-direccion">
                        <i class="oi oi-magnifying-glass me-1"></i> Buscar
                    </button>
                </div>
                <!-- Contenedor del mapa -->
                <div id="leaflet-map" class="map-container" style="width: 100%; height: 400px;"></div>
                <!-- Información de la dirección seleccionada -->
                <div class="direccion-info">
                    <p class="mb-0"><strong>Dirección seleccionada:</strong> <span id="direccion-seleccionada">Ninguna</span></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CerrarModalMapa">Cancelar</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmarDireccion">
                    <i class="oi oi-check me-1"></i> Confirmar ubicación
                </button>
            </div>
        </div>
    </div>
    @if (mostrarModalMapa)
    {
        <!-- Usar una implementación personalizada del backdrop -->
        <div class="modal-backdrop show" style="pointer-events: none;"></div>
    }
</div>

@code {
    private PersonaDTO modelo = new PersonaDTO();
    private string prefijoPais = "Bo +591"; // Prefijo por defecto (Bolivia)
    private int pasoActual = 1;  // Control del paso actual del formulario

    // Variables para el modal de la cámara
    private bool mostrarModalCamara = false;
    private string tipoImagenActual = "frontal"; // Puede ser: "frontal", "izquierda", "derecha"
    private string tituloModalCamara = "Tomar foto de perfil";

    // Variables para el mapa de Leaflet
    private bool mostrarModalMapa = false;
    private double latitudSeleccionada = 0;
    private double longitudSeleccionada = 0;

    // Lista de prefijos telefónicos más comunes
    private List<string> prefijosPaises = new List<string>
    {
        "BO +591", // Bolivia
        "+54",  // Argentina
        "+55",  // Brasil
        "+56",  // Chile
        "+57",  // Colombia
        "+593", // Ecuador
        "+52",  // México
        "+51",  // Perú
        "+598", // Uruguay
        "+58",  // Venezuela
        "+34",  // España
        "+1",   // Estados Unidos/Canadá
        "+44",  // Reino Unido
        "+33",  // Francia
        "+49",  // Alemania
        "+39",  // Italia
        "+351", // Portugal
        "+81",  // Japón
        "+86",  // China
        "+7",   // Rusia
    };

    protected override void OnInitialized()
    {
        // Inicialización por defecto
        if (string.IsNullOrEmpty(modelo.Telefono))
        {
            modelo.Telefono = "";
        }

        // Valores predeterminados para la dirección
        modelo.Pais = "Bolivia";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Cargar el JavaScript para la cámara - archivo externo
            await JSRuntime.InvokeVoidAsync("import", "./js/camera.js");

            // Cargar el JavaScript para el mapa - archivo externo
            await JSRuntime.InvokeVoidAsync("import", "./js/map.js");
        }
    }

    private void SiguientePaso()
    {
        // Validar campos del paso actual antes de avanzar
        if (pasoActual == 1)
        {
            // Validaciones básicas del paso 1
            if (string.IsNullOrEmpty(modelo.Nombre) ||
                string.IsNullOrEmpty(modelo.ApellidoPaterno) ||
                string.IsNullOrEmpty(modelo.ApellidoMaterno) ||
                string.IsNullOrEmpty(modelo.TipoDocumento) ||
                string.IsNullOrEmpty(modelo.NumeroDocumento) ||
                string.IsNullOrEmpty(modelo.Correo) ||
                string.IsNullOrEmpty(modelo.Clave) ||
                string.IsNullOrEmpty(modelo.ConfirmarClave))
            {
                toastService.ShowWarning("Por favor, complete todos los campos obligatorios");
                return;
            }

            // Validar que las contraseñas coincidan
            if (modelo.Clave != modelo.ConfirmarClave)
            {
                toastService.ShowWarning("Las contraseñas no coinciden");
                return;
            }
        }
        else if (pasoActual == 2)
        {
            // Validaciones básicas del paso 2
            if (string.IsNullOrEmpty(modelo.Direccion) ||
                string.IsNullOrEmpty(modelo.Ciudad) ||
                string.IsNullOrEmpty(modelo.Pais))
            {
                toastService.ShowWarning("Por favor, complete todos los campos obligatorios");
                return;
            }
        }

        if (pasoActual < 3)
        {
            pasoActual++;
        }
    }

    private void PasoAnterior()
    {
        if (pasoActual > 1)
        {
            pasoActual--;
        }
    }

    // Métodos para el mapa de Leaflet
    private async Task AbrirMapaSeleccionDireccion()
    {
        mostrarModalMapa = true;
        StateHasChanged();

        // Pequeña espera para asegurar que el DOM está actualizado
        await Task.Delay(100);

        // Inicializar el mapa después de mostrar el modal
        bool mapaIniciado = await JSRuntime.InvokeAsync<bool>("inicializarMapa");
        if (!mapaIniciado)
        {
            toastService.ShowError("No se pudo inicializar el mapa. Por favor, verifique los permisos e intente nuevamente.");
            CerrarModalMapa();
        }
    }

    private void CerrarModalMapa()
    {
        mostrarModalMapa = false;
        StateHasChanged();
    }

    private async Task ConfirmarDireccion()
    {
        try
        {
            // Obtenemos el objeto como string JSON para evitar problemas de deserialización
            var jsonResult = await JSRuntime.InvokeAsync<string>("JSON.stringify",
                await JSRuntime.InvokeAsync<object>("obtenerDireccionSeleccionada"));

            // Lo deserializamos manualmente con opciones personalizadas
            var options = new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                };

            var direccionObj = System.Text.Json.JsonSerializer.Deserialize<DireccionMapaInfo>(jsonResult, options);

            if (direccionObj != null && !string.IsNullOrEmpty(direccionObj.Direccion))
            {
                // Actualizamos el modelo
                modelo.Direccion = direccionObj.Direccion;
                modelo.Latitud = direccionObj.Latitud;
                modelo.Longitud = direccionObj.Longitud;

                // Actualizamos variables locales
                latitudSeleccionada = direccionObj.Latitud;
                longitudSeleccionada = direccionObj.Longitud;

                // Cerramos el modal
                CerrarModalMapa();
                toastService.ShowSuccess("Dirección seleccionada correctamente");
            }
            else
            {
                toastService.ShowWarning("No se ha seleccionado ninguna dirección");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en ConfirmarDireccion: {ex.Message}");
            Console.WriteLine($"StackTrace: {ex.StackTrace}");
            toastService.ShowError($"Error al confirmar la dirección: {ex.Message}");
        }
    }

