    // Métodos para manejar la carga de imágenes mediante archivo
    private async Task OnFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            FileInfo fileInfo = new FileInfo(e.File.Name);
            if (fileInfo.Extension.ToLower().Contains(".jpg") ||
                fileInfo.Extension.ToLower().Contains(".jpeg") ||
                fileInfo.Extension.ToLower().Contains(".png"))
            {
                var format = fileInfo.Extension.ToLower().Contains(".jpg") ||
                             fileInfo.Extension.ToLower().Contains(".jpeg")
                             ? "image/jpeg" : "image/png";

                var resizeImage = await e.File.RequestImageFileAsync(format, 300, 200);
                var buffer = new byte[resizeImage.Size];
                await resizeImage.OpenReadStream().ReadAsync(buffer);
                var imageData = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
                modelo.Imagen = imageData;
            }
            else
            {
                toastService.ShowWarning("Por favor, seleccione un archivo de imagen válido (JPG, JPEG o PNG)");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error al cargar la imagen: {ex.Message}");
        }
    }

    private void LimpiarImagen()
    {
        modelo.Imagen = null;
    }

    // Métodos para la cámara web
    private async Task ActivarCamara()
    {
        tipoImagenActual = "frontal";
        tituloModalCamara = "Tomar foto de perfil";
        mostrarModalCamara = true;
        StateHasChanged();

        // Iniciar la cámara después de mostrar el modal
        bool camaraIniciada = await JSRuntime.InvokeAsync<bool>("iniciarCamara");
        if (!camaraIniciada)
        {
            toastService.ShowError("No se pudo acceder a la cámara. Por favor, verifique los permisos de su navegador.");
            CerrarModalCamara();
        }
    }

    private async Task TomarFoto()
    {
        // Capturar la foto actual de la cámara
        await JSRuntime.InvokeVoidAsync("tomarFoto");
    }

    private async Task ReintentarFoto()
    {
        // Reiniciar la cámara para tomar otra foto
        await JSRuntime.InvokeVoidAsync("reiniciarCamara");
    }

    private async Task GuardarFoto()
    {
        try
        {
            // Obtener la imagen capturada directamente
            var imagenBase64 = await JSRuntime.InvokeAsync<string>("obtenerImagenCapturada");

            if (string.IsNullOrEmpty(imagenBase64))
            {
                toastService.ShowError("No se pudo obtener la imagen capturada");
                return;
            }

            // Asignar la imagen al campo correspondiente según el tipo
            switch (tipoImagenActual)
            {
                case "frontal":
                    modelo.Imagen = imagenBase64;
                    break;
            }

            // Cerrar el modal
            CerrarModalCamara();
            toastService.ShowSuccess("Foto capturada correctamente");
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error al guardar la imagen: {ex.Message}");
        }
    }

    private async Task CerrarModalCamara()
    {
        // Detener la cámara antes de cerrar el modal
        await JSRuntime.InvokeVoidAsync("detenerCamara");
        mostrarModalCamara = false;
        StateHasChanged();
    }

    // Este método se ejecuta cuando cambia el prefijo del país
    private void PrefijoCambiado(ChangeEventArgs e)
    {
        prefijoPais = e.Value?.ToString() ?? "+591";
        // Actualizar el teléfono con el nuevo prefijo
        ActualizarTelefono();
    }

    // Este método se ejecuta cuando cambia el número de teléfono
    private void TelefonoCambiado(ChangeEventArgs e)
    {
        string numeroSinPrefijo = e.Value?.ToString() ?? "";

        // Asegurarse de que el número no comience con el prefijo (evitar duplicación)
        if (numeroSinPrefijo.StartsWith(prefijoPais))
        {
            numeroSinPrefijo = numeroSinPrefijo.Substring(prefijoPais.Length);
        }

        // Actualizar el modelo con el prefijo + número
        modelo.Telefono = $"{prefijoPais}{numeroSinPrefijo}";
    }

    // Método auxiliar para actualizar el teléfono cuando cambia el prefijo
    private void ActualizarTelefono()
    {
        if (!string.IsNullOrEmpty(modelo.Telefono))
        {
            // Extraer la parte numérica sin prefijo
            string numeroSinPrefijo = modelo.Telefono;
            foreach (var prefijo in prefijosPaises)
            {
                if (numeroSinPrefijo.StartsWith(prefijo))
                {
                    numeroSinPrefijo = numeroSinPrefijo.Substring(prefijo.Length);
                    break;
                }
            }

            // Combinar el nuevo prefijo con el número
            modelo.Telefono = $"{prefijoPais}{numeroSinPrefijo}";
        }
        else
        {
            // Si no hay número, simplemente usar el prefijo
            modelo.Telefono = prefijoPais;
        }
    }

    private async Task GuardarCambios()
    {
        try
        {
            // Asegurarse de que el teléfono incluya el prefijo
            if (!string.IsNullOrEmpty(modelo.Telefono) && !modelo.Telefono.StartsWith(prefijoPais))
            {
                modelo.Telefono = $"{prefijoPais}{modelo.Telefono}";
            }

            if (modelo.Clave != modelo.ConfirmarClave)
            {
                toastService.ShowWarning("Las contraseñas no coinciden");
                return;
            }

            // Generar el nombre completo antes de guardar
            modelo.NombreCompleto = $"{modelo.Nombre} {modelo.ApellidoPaterno} {modelo.ApellidoMaterno ?? ""}".Trim();

            // Asegurar que se usen las coordenadas correctas
            if (modelo.Latitud == 0 && modelo.Longitud == 0)
            {
                modelo.Latitud = latitudSeleccionada;
                modelo.Longitud = longitudSeleccionada;
            }

            // Asignar rol por defecto
            modelo.Rol = "Cliente";

            // Si está habilitado el reconocimiento facial pero no hay imagen facial
            if (modelo.UseFacialRecognition && string.IsNullOrEmpty(modelo.FacialImage))
            {
                // Si hay imagen de perfil, usamos esa
                if (!string.IsNullOrEmpty(modelo.Imagen))
                {
                    modelo.FacialImage = modelo.Imagen;
                }
                else
                {
                    toastService.ShowWarning("Debe capturar una imagen facial o deshabilitar el reconocimiento facial");
                    return;
                }
            }

            // Invocar al servicio para crear el usuario
            var response = await _personaServicio.Crear(modelo);

            if (response.EsCorrecto)
            {
                toastService.ShowSuccess("Registro exitoso. Su cuenta ha sido creada.");
                _navServicio.NavigateTo("/login");
            }
            else
            {
                toastService.ShowError(response.Mensaje ?? "Error al crear la cuenta. Intente nuevamente.");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error durante el registro: {ex.Message}");
        }
    }

    private void UsarImagenPerfilParaFacial()
    {
        if (!string.IsNullOrEmpty(modelo.Imagen))
        {
            modelo.FacialImage = modelo.Imagen;
            toastService.ShowSuccess("La imagen facial ha sido configurada correctamente");
        }
    }
