@page "/login"
@using BlazorEcommerce.Client.Extensiones
@using BlazorEcommerce.Shared
@using Microsoft.AspNetCore.Components.Authorization
@layout LoginLayout
@inject IPersonaServicio _personaServicio
@inject NavigationManager _navServicio
@inject IToastService toastService
@inject AuthenticationStateProvider autenticacionProvider
@inject IJSRuntime JSRuntime
<div class="container login-container">
    <div class="row justify-content-end">
        <div class="col-auto">
            <button class="btn btn-outline-light" @onclick="VolverAlMenu">
                <i class="oi oi-arrow-left me-1"></i> Volver
            </button>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card rounded-lg mt-4 login-card">
                <div class="card-header login-header">
                    <h3 class="text-center font-weight-light my-3">
                        <span class="login-title-red">Inicio de </span><span class="login-title-black">Sesión</span>
                    </h3>

                    <!-- Pestañas para seleccionar el método de login -->
                    <ul class="nav nav-tabs card-header-tabs login-tabs">
                        <li class="nav-item">
                            <a class="nav-link @(mostrarLoginFacial ? "" : "active")" @onclick="() => CambiarMetodoLogin(false)">
                                <i class="oi oi-lock-locked me-1"></i> Tradicional
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(mostrarLoginFacial ? "active" : "")" @onclick="() => CambiarMetodoLogin(true)">
                                <i class="oi oi-camera-slr me-1"></i> Facial
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="card-body login-body">
                    @if (!mostrarLoginFacial)
                    {
                        <!-- Login tradicional -->
                        <EditForm Model="modelo" OnValidSubmit="Iniciar">
                            <DataAnnotationsValidator></DataAnnotationsValidator>
                            <div class="form-floating mb-4">
                                <input class="form-control login-input" id="inputEmail" type="email" placeholder="admin@example.com" @bind-value="modelo.Correo" autocomplete="off" />
                                <label for="inputEmail">Correo electrónico</label>
                                <ValidationMessage For="@(()=>modelo.Correo)" class="text-danger" />
                            </div>
                            <div class="form-floating mb-4">
                                <input class="form-control login-input" id="inputPassword" type="password" placeholder="123" @bind-value="modelo.Clave" autocomplete="off" />
                                <label for="inputPassword">Contraseña</label>
                                <ValidationMessage For="@(()=>modelo.Clave)" class="text-danger" />
                            </div>
                            <div class="d-grid gap-2 mt-4 mb-0">
                                <button class="btn btn-login" type="submit">
                                    <i class="oi oi-account-login me-1"></i> Ingresar
                                </button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <!-- Login con reconocimiento facial -->
                        <div class="mb-4 text-center">
                            <p class="login-subtitle">Ingrese su correo y use su cámara para iniciar sesión</p>
                        </div>

                        <div class="form-floating mb-4">
                            <input class="form-control login-input" id="inputFacialEmail" type="email"
                                   placeholder="correo@ejemplo.com" @bind-value="facialLoginDTO.Correo" />
                            <label for="inputFacialEmail">Correo electrónico</label>
                        </div>

                        <div class="text-center mb-4">
                            @if (string.IsNullOrEmpty(facialLoginDTO.FacialImage))
                            {
                                <button class="btn btn-camera" @onclick="ActivarCamara">
                                    <i class="oi oi-camera-slr me-1"></i> Activar cámara
                                </button>
                            }
                            else
                            {
                                <div class="mb-3 facial-image-container">
                                    <img src="@facialLoginDTO.FacialImage" class="img-fluid rounded facial-image"
                                         alt="Imagen facial" />
                                </div>
                                <button class="btn btn-outline-danger me-2" @onclick="LimpiarImagenFacial">
                                    <i class="oi oi-trash me-1"></i> Eliminar
                                </button>
                            }
                        </div>

                        <div class="d-grid gap-2 mt-4 mb-0">
                            <button class="btn btn-login" @onclick="IniciarConFacial"
                                    disabled="@(string.IsNullOrEmpty(facialLoginDTO.Correo) ||
                                              string.IsNullOrEmpty(facialLoginDTO.FacialImage))">
                                <i class="oi oi-account-login me-1"></i> Iniciar sesión con facial
                            </button>
                        </div>
                    }
                </div>
                <div class="card-footer login-footer text-center py-3">
                    <div class="small">
                        <a href="/registrarse" class="register-link">
                            <span class="register-red">¿No tienes una</span> <span class="register-black">cuenta? ¡Regístrate!</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para la cámara -->
<div class="modal fade @(mostrarModalCamara ? "show" : "")"
     style="display: @(mostrarModalCamara ? "block" : "none")">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Capturar imagen facial</h5>
                <button type="button" class="btn-close" @onclick="CerrarModalCamara"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12 text-center">
                        <video id="video" style="max-width:100%; height:auto; border:1px solid #ddd;" autoplay></video>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 text-center">
                        <canvas id="canvas" style="display:none;"></canvas>
                        <img id="capturedImage" class="img-fluid" style="max-height:200px; display:none;" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CerrarModalCamara">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnCapturar" @onclick="TomarFoto">
                    <i class="oi oi-camera-slr"></i> Capturar Foto
                </button>
                <button type="button" class="btn btn-success" id="btnGuardar" style="display:none;" @onclick="GuardarFoto">
                    <i class="oi oi-check"></i> Usar esta foto
                </button>
                <button type="button" class="btn btn-warning" id="btnReintentar" style="display:none;" @onclick="ReintentarFoto">
                    <i class="oi oi-action-redo"></i> Reintentar
                </button>
            </div>
        </div>
    </div>

    @if (mostrarModalCamara)
    {
        <!-- Usar una implementación personalizada del backdrop que permita que los eventos se propaguen al modal -->
        <div class="modal-backdrop show" style="pointer-events: none;"></div>
    }
</div>
    

@code {
    private LoginDTO modelo = new LoginDTO();
    private FacialLoginDTO facialLoginDTO = new FacialLoginDTO();
    private bool mostrarLoginFacial = false;
    private bool mostrarModalCamara = false;

    // Método para cambiar entre login tradicional y facial
    private void CambiarMetodoLogin(bool usarFacial)
    {
        mostrarLoginFacial = usarFacial;
    }

    private async Task ActivarCamara()
    {
        mostrarModalCamara = true;
        StateHasChanged();

        // Iniciar la cámara después de que el modal esté visible
        await Task.Delay(100); // Pequeño retraso para asegurar que el DOM esté actualizado
        await JSRuntime.InvokeVoidAsync("iniciarCamara");
    }

    private async Task TomarFoto()
    {
        await JSRuntime.InvokeVoidAsync("tomarFoto");
    }

    private async Task ReintentarFoto()
    {
        await JSRuntime.InvokeVoidAsync("reiniciarCamara");
    }

    private async Task GuardarFoto()
    {
        try
        {
            var imagenBase64 = await JSRuntime.InvokeAsync<string>("obtenerImagenCapturada");

            if (!string.IsNullOrEmpty(imagenBase64))
            {
                facialLoginDTO.FacialImage = imagenBase64;
                await CerrarModalCamara();
            }
            else
            {
                toastService.ShowError("No se pudo obtener la imagen");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error al guardar la foto: {ex.Message}");
        }
    }

    private async Task CerrarModalCamara()
    {
        await JSRuntime.InvokeVoidAsync("detenerCamara");
        mostrarModalCamara = false;
    }

    private void LimpiarImagenFacial()
    {
        facialLoginDTO.FacialImage = string.Empty;
    }

    private async Task IniciarConFacial()
    {
        if (string.IsNullOrEmpty(facialLoginDTO.Correo) || string.IsNullOrEmpty(facialLoginDTO.FacialImage))
        {
            toastService.ShowWarning("Debe ingresar su correo y capturar su imagen facial");
            return;
        }

        try
        {
            var response = await _personaServicio.AutorizacionFacial(facialLoginDTO);

            if (response.EsCorrecto)
            {
                SesionDTO sesion = (SesionDTO)response.Resultado!;
                var autenticacionExt = (AutenticacionExtension)autenticacionProvider;
                await autenticacionExt.ActualizarEstadoAutenticacion(sesion);

                if (sesion.Rol.ToLower() == "cliente")
                    _navServicio.NavigateTo("/catalogo");
                else
                    _navServicio.NavigateTo("/dashboard");
            }
            else
            {
                toastService.ShowWarning(response.Mensaje!);
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error: {ex.Message}");
        }
    }

    private async Task Iniciar()
    {
        var response = await _personaServicio.Autorizacion(modelo);
        if (response.EsCorrecto)
        {
            SesionDTO sesion = (SesionDTO)response.Resultado!;
            var autenticacionExt = (AutenticacionExtension)autenticacionProvider;
            await autenticacionExt.ActualizarEstadoAutenticacion(sesion);
            if (sesion.Rol.ToLower() == "cliente")
                _navServicio.NavigateTo("/catalogo");
            else
                _navServicio.NavigateTo("/dashboard");
        }
        else
        {
            toastService.ShowWarning(response.Mensaje!);
        }
    }

    private void VolverAlMenu()
    {
        _navServicio.NavigateTo("/catalogo");
    }
}