@page "/"
@page "/catalogo"
@inject IProductoServicio productoServicio;
@inject ICategoriaServicio categoriaServicio;
@inject NavigationManager navManager

<div class="container catalog-container">
    <div class="row justify-content-center mt-3 mb-4">
        <div class="col-sm-12 col-md-10 col-lg-8">
            <div class="input-group search-bar">
                <input type="text" class="form-control search-input" placeholder="Buscar productos..." @bind-value="buscar">
                <button class="btn search-button" type="button" @onclick="(async () => await ObtenerCatalogo())">
                    <i class="oi oi-magnifying-glass"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-3 col-md-4">
            <div class="card category-card">
                <div class="card-header category-header">
                    <i class="oi oi-list me-2"></i>Categorías
                </div>
                <div class="card-body category-body">
                    @if (listaCategoria != null)
                    {
                        <div class="category-radio">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="categoria" id="Todos" value="Todos"
                                       @onchange="RadioSeleccion"
                                       checked=@(categoriaSeleccionada.Equals("Todos"))>
                                <label class="form-check-label" for="Todos">
                                    Todos los productos
                                </label>
                            </div>
                            @foreach (var item in listaCategoria)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="categoria" id="@item.IdCategoria" value="@item.Nombre"
                                           @onchange="RadioSeleccion"
                                           checked=@(categoriaSeleccionada.Equals(item.Nombre,StringComparison.OrdinalIgnoreCase))>
                                    <label class="form-check-label" for="@item.IdCategoria">
                                        @item.Nombre
                                    </label>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            @if (listaProducto != null)
            {
                <div class="row product-grid g-4">
                    @foreach (var item in listaProducto)
                    {
                        <div class="col-xl-4 col-lg-6 col-md-12 col-sm-6 mb-4">
                            <div class="product-card">
                                <div class="product-img-container">
                                    @if (!string.IsNullOrEmpty(item.Etiqueta))
                                    {
                                        @switch (item.Etiqueta)
                                        {
                                            case "Nuevo":
                                                <div class="product-badge badge-new">@item.Etiqueta</div>
                                                break;
                                            case "Ultima Unidad":
                                                <div class="product-badge badge-last">@item.Etiqueta</div>
                                                break;
                                            case "Combo":
                                                <div class="product-badge badge-combo">@item.Etiqueta</div>
                                                break;
                                            case "Oferta":
                                                <div class="product-badge badge-offer">@item.Etiqueta</div>
                                                break;
                                            default:
                                                <div class="product-badge badge-new">@item.Etiqueta</div>
                                                break;
                                        }
                                    }
                                    <img class="product-img" src="@item.Imagen" alt="@item.Nombre">
                                </div>
                                <div class="product-body">
                                    <h5 class="product-title">@item.Nombre</h5>
                                    <p class="product-code">Código: @item.Producto</p>

                                    <div class="product-price-container">
                                        @if (item.PrecioOferta != 0 && item.PrecioOferta < item.Precio)
                                        {
                                            <div class="product-price-original">Bs. @item.Precio</div>
                                            <div class="product-price-offer">Bs. @item.PrecioOferta</div>
                                        }
                                        else
                                        {
                                            <div class="product-price">Bs. @item.Precio</div>
                                        }
                                    </div>
                                </div>
                                <div class="product-footer">
                                    <a class="btn btn-view-product" href="/detalle/@item.IdProducto">
                                        <i class="oi oi-eye me-1"></i> Ver detalle
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center">
                    <div class="spinner-border catalog-spinner" role="status">
                        <span class="visually-hidden">Cargando productos...</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {


    private List<CategoriaDTO>? listaCategoria = null;
    private List<ProductoDTO>? listaProducto = null;
    private string buscar = "";
    private string categoriaSeleccionada = "Todos";

    private async Task ObtenerCategorias(string Valor = "")
    {
        var response = await categoriaServicio.Lista(Valor);

        if (response.EsCorrecto)
        {
            listaCategoria = (List<CategoriaDTO>)response.Resultado!;
        }
        else
        {
            listaCategoria = new List<CategoriaDTO>();
        }
    }
    private async Task ObtenerCatalogo()
    {
        var response = await productoServicio.Catalogo(categoriaSeleccionada, buscar);

        if (response.EsCorrecto)
        {
            listaProducto = (List<ProductoDTO>)response.Resultado!;
        }
        else
        {
            listaProducto = new List<ProductoDTO>();
        }
    }

    private async Task RadioSeleccion(ChangeEventArgs args)
    {
        categoriaSeleccionada = args.Value.ToString();
        buscar = "";
        await ObtenerCatalogo();
    }

    protected override async Task OnInitializedAsync()
    {
        await ObtenerCategorias();
        await ObtenerCatalogo();
    }
}
