@page "/checkout"
@inject ICarritoServicio carritoServicio
@inject IVentaServicio ventaServicio
@inject IPersonaServicio _personaServicio
@inject IToastService toastService
@inject NavigationManager _navServicio
@inject IJSRuntime JSRuntime
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using BlazorEcommerce.Shared
@attribute [Authorize]

<div class="container mt-4 mb-5">
    <h3 class="mb-4">Finalizar Compra</h3>

    <div class="row">
        <!-- Columna izquierda con datos personales, envío y pago -->
        <div class="col-md-8">
            <!-- Datos Personales -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Datos personales</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Correo Electrónico *</label>
                            <input type="email" class="form-control" @bind="datosPersona.Correo" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nombre *</label>
                            <input type="text" class="form-control" @bind="datosPersona.Nombre" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Apellido Paterno *</label>
                            <input type="text" class="form-control" @bind="datosPersona.ApellidoPaterno" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Apellido Materno</label>
                            <input type="text" class="form-control" @bind="datosPersona.ApellidoMaterno" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tipo de Documento</label>
                            <select class="form-select" @bind="datosPersona.TipoDocumento">
                                <option value="">Seleccione tipo...</option>
                               
                                <option value="CI">Carnet de Identidad</option>
                                <option value="Pasaporte">Pasaporte</option>
                                <option value="NIT">NIT</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Número de Documento</label>
                            <input type="text" class="form-control" @bind="datosPersona.NumeroDocumento" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Ciudad *</label>
                            <input type="text" class="form-control" @bind="direccionEnvio.Ciudad" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Teléfono/Celular *</label>
                            <div class="input-group">
                                <select class="form-select" style="max-width: 30%;" @bind="prefijoPais" @bind:after="ActualizarTelefono">
                                    @foreach (var prefijo in prefijosPaises)
                                    {
                                            <option value="@prefijo">@prefijo</option>
                                    }
                                </select>
                                <input type="tel" class="form-control" @bind="telefonoSinPrefijo" @bind:after="ActualizarTelefono" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección *</label>
                        <input type="text" class="form-control" @bind="direccionEnvio.DireccionCompleta" />
                    </div>
                </div>
            </div>

            <!-- Método de Envío -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Método de Envío</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="metodoEnvio" 
                               id="recojo" value="recojo" checked="@(metodoEnvio == "recojo")" 
                               @onchange="@(() => CambiarMetodoEnvio("recojo"))" />
                        <label class="form-check-label" for="recojo">
                            Recojo en Tienda <i class="oi oi-home text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="mb-3 @(metodoEnvio == "recojo" ? "" : "d-none")">
                        <select class="form-select mb-3">
                            <option value="" selected>Seleccione la oficina</option>
                            <option value="1">Santa Cruz - Oficina Central</option>
                            <option value="2">La Paz - Sucursal</option>
                            <option value="3">Cochabamba - Sucursal</option>
                        </select>

                        <div id="mapa" style="height: 250px; width: 100%;" class="border rounded">
                            <!-- Mensaje alternativo mientras el mapa se carga -->
                            <div class="d-flex justify-content-center align-items-center h-100 bg-light">
                                <p class="text-muted">Mapa de nuestras tiendas</p>
                            </div>
                        </div>

                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="metodoEnvio" 
                               id="delivery" value="delivery" checked="@(metodoEnvio == "delivery")" 
                               @onchange="@(() => CambiarMetodoEnvio("delivery"))" />
                        <label class="form-check-label" for="delivery">
                            Delivery <i class="oi oi-truck text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="@(metodoEnvio == "delivery" ? "mt-3" : "d-none")">
                        <div class="alert alert-info">
                            <small>El costo de delivery es de Bs. 20. Por favor asegúrese de proporcionar una dirección completa y correcta.</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Método de Pago -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Método de pago</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="metodoPago" id="depositoBancario" 
                               value="deposito" checked="@(metodoPago == "deposito")" 
                               @onchange="@(() => metodoPago = "deposito")" />
                        <label class="form-check-label" for="depositoBancario">
                            Depósito Bancario <i class="oi oi-credit-card text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="metodoPago" id="transferencia" 
                               value="transferencia" checked="@(metodoPago == "transferencia")" 
                               @onchange="@(() => metodoPago = "transferencia")" />
                        <label class="form-check-label" for="transferencia">
                            Transferencia Bancaria <i class="oi oi-transfer text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="metodoPago" id="pagoTienda" 
                               value="tienda" checked="@(metodoPago == "tienda")" 
                               @onchange="@(() => metodoPago = "tienda")" />
                        <label class="form-check-label" for="pagoTienda">
                            Pago en tienda <i class="oi oi-dollar text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="metodoPago" id="tarjeta" 
                               value="tarjeta" checked="@(metodoPago == "tarjeta")" 
                               @onchange="@(() => metodoPago = "tarjeta")" />
                        <label class="form-check-label" for="tarjeta">
                            Tarjeta de Débito y Crédito <i class="oi oi-credit-card text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="radio" name="metodoPago" id="codigo" 
                               value="codigo" checked="@(metodoPago == "codigo")" 
                               @onchange="@(() => metodoPago = "codigo")" />
                        <label class="form-check-label" for="codigo">
                            Pago con Código QR <i class="oi oi-qr-code text-primary ms-1"></i>
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="metodoPago" id="afiliado" 
                               value="afiliado" checked="@(metodoPago == "afiliado")" 
                               @onchange="@(() => metodoPago = "afiliado")" />
                        <label class="form-check-label" for="afiliado">
                            Pago en comercios afiliados <i class="oi oi-people text-primary ms-1"></i>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna derecha con resumen de orden -->
        <div class="col-md-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Resumen de orden</h5>
                </div>
                <div class="card-body">
                    <p>@(productos?.Count ?? 0) Productos en el Carrito</p>

                    @if (productos != null && productos.Any())
                    {
                        foreach (var item in productos)
                        {
                                    <div class="d-flex mb-3 border-bottom pb-3">
                                        <div style="width: 60px; height: 60px;" class="flex-shrink-0">
                                            <img src="@item.Producto?.Imagen" class="img-fluid rounded" 
                                                 style="width: 100%; height: 100%; object-fit: cover;" 
                                                 alt="@item.Producto?.Nombre">
                                        </div>
                                        <div class="ms-3 flex-grow-1">
                                            <h6 class="mb-0">@item.Producto?.Nombre</h6>
                                            <p class="text-muted small mb-1">@item.Producto?.Producto</p>
                                            <div class="d-flex justify-content-between">
                                                <span>@item.Cantidad x Bs. @item.Precio</span>
                                                <strong>Bs. @item.Total</strong>
                                            </div>
                                        </div>
                                    </div>
                        }
                    }
                    else
                    {
                            <div class="alert alert-warning">
                                No hay productos en el carrito
                            </div>
                    }

                    <div class="border-top pt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <strong>Bs. @subtotal</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Envío</span>
                            <strong>Bs. @costoEnvio</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2 pt-2 border-top fw-bold">
                            <span>Total a Pagar:</span>
                            <strong>Bs. @total</strong>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-danger" type="button" @onclick="FinalizarCompra">COMPRAR AHORA</button>
                        <a href="/cart" class="btn btn-outline-secondary">Volver al Carrito</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationState { get; set; }

    // Datos de persona
    private PersonaDTO datosPersona = new PersonaDTO();

    // Variables para teléfono
    private string prefijoPais = "+591";
    private string telefonoSinPrefijo = "";

    // Lista de prefijos telefónicos
    private List<string> prefijosPaises = new List<string>
    {
        "+591", // Bolivia
        "+54",  // Argentina
        "+55",  // Brasil
        "+56",  // Chile
        "+57",  // Colombia
        "+593", // Ecuador
        "+52",  // México
        "+51",  // Perú
        "+598", // Uruguay
        "+58",  // Venezuela
        "+34",  // España
        "+1",   // Estados Unidos/Canadá
    };

    // Dirección de envío
    private DireccionEnvio direccionEnvio = new DireccionEnvio();

    // Métodos
    private string metodoEnvio = "recojo";
    private string metodoPago = "deposito";

    // Datos del carrito
    private List<CarritoDTO> productos = new List<CarritoDTO>();
    private decimal? subtotal = 0;
    private decimal? costoEnvio = 0;
    private decimal? total = 0;

    // Para almacenar la sesión del usuario
    private SesionDTO sesionUsuario = null;

  protected override async Task OnInitializedAsync()
{
    try
    {
        // Verificar si el usuario está autenticado
        var authState = await authenticationState;
        if (!authState.User.Identity.IsAuthenticated)
        {
            toastService.ShowWarning("Debe iniciar sesión para continuar con la compra");
            _navServicio.NavigateTo("/login");
            return;
        }
        
        // Obtener datos del usuario actual
        var userIdClaim = authState.User.FindFirst("IdUsuario") ?? authState.User.FindFirst(ClaimTypes.NameIdentifier);
        
        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId) && userId > 0)
        {
            var response = await _personaServicio.Obtener(userId);
            if (response.EsCorrecto && response.Resultado != null)
            {
                datosPersona = response.Resultado;
                
                // Si hay teléfono, separar el prefijo
                if (!string.IsNullOrEmpty(datosPersona.Telefono))
                {
                    SepararTelefono(datosPersona.Telefono);
                }
            }
            else
            {
                // Alternativa: intentar buscar por correo electrónico
                var email = authState.User.FindFirst(ClaimTypes.Email)?.Value ?? authState.User.Identity.Name;
                
                if (!string.IsNullOrEmpty(email))
                {
                    var personasResponse = await _personaServicio.Lista("", email);
                    if (personasResponse.EsCorrecto && personasResponse.Resultado != null && personasResponse.Resultado.Any())
                    {
                        datosPersona = personasResponse.Resultado.First();
                        
                        // Si hay teléfono, separar el prefijo
                        if (!string.IsNullOrEmpty(datosPersona.Telefono))
                        {
                            SepararTelefono(datosPersona.Telefono);
                        }
                    }
                }
            }
        }
        
        // Cargar productos del carrito
        productos = await carritoServicio.DevolverCarrito();
        
        if (productos == null || !productos.Any())
        {
            toastService.ShowWarning("No hay productos en el carrito");
            _navServicio.NavigateTo("/cart");
            return;
        }
        
        // Calcular los totales
        CalcularTotales();
    }
    catch (Exception ex)
    {
        toastService.ShowError($"Error al cargar la página: {ex.Message}");
    }
}

    private void SepararTelefono(string telefono)
    {
        if (string.IsNullOrEmpty(telefono))
            return;

        foreach (var prefijo in prefijosPaises)
        {
            if (telefono.StartsWith(prefijo))
            {
                prefijoPais = prefijo;
                telefonoSinPrefijo = telefono.Substring(prefijo.Length);
                return;
            }
        }

        // Si no se encuentra un prefijo conocido, usar el valor completo
        telefonoSinPrefijo = telefono;
    }

    private void ActualizarTelefono()
    {
        datosPersona.Telefono = $"{prefijoPais}{telefonoSinPrefijo}";
    }

    private void CalcularTotales()
    {
        // Asegurarse de que productos no sea nulo
        if (productos == null)
        {
            productos = new List<CarritoDTO>();
            subtotal = 0;
            total = 0;
            return;
        }

        // Calcular subtotal con manejo de valores nulos
        subtotal = productos.Sum(p => p.Total ?? 0);

        // Aplicar costo de envío si es delivery
        costoEnvio = metodoEnvio == "delivery" ? 20 : 0;

        // Calcular total
        total = subtotal + costoEnvio;
    }

    // Método que se ejecuta cuando cambia el método de envío
    private void CambiarMetodoEnvio(string nuevoMetodo)
    {
        metodoEnvio = nuevoMetodo;
        CalcularTotales(); // Recalcular totales para actualizar costo de envío
    }

    // Método para inicializar el mapa (simulado en este ejemplo)
    private async Task InicializarMapa()
    {
        await JSRuntime.InvokeVoidAsync("inicializarMapa");
    }

    private async Task FinalizarCompra()
    {
        // Validar datos obligatorios
        if (string.IsNullOrEmpty(datosPersona.Nombre) ||
            string.IsNullOrEmpty(datosPersona.ApellidoPaterno) ||
            string.IsNullOrEmpty(datosPersona.Correo) ||
            string.IsNullOrEmpty(datosPersona.Telefono))
        {
            toastService.ShowWarning("Por favor complete todos los datos personales obligatorios");
            return;
        }

        // Si es delivery, validar dirección
        if (metodoEnvio == "delivery" && string.IsNullOrEmpty(direccionEnvio.DireccionCompleta))
        {
            toastService.ShowWarning("Por favor ingrese la dirección de envío");
            return;
        }

        try
        {
            // Crear detalle de venta
            List<DetalleVentaDTO> detalle = new List<DetalleVentaDTO>();
            foreach (var item in productos)
            {
                if (item.Producto != null && item.Cantidad > 0)
                {
                    detalle.Add(new DetalleVentaDTO
                        {
                            IdProducto = item.Producto.IdProducto,
                            Cantidad = item.Cantidad,
                            Total = item.Total
                        });
                }
            }

            // Si no hay detalles válidos, mostrar error
            if (!detalle.Any())
            {
                toastService.ShowError("No hay productos válidos en el carrito");
                return;
            }

            // Actualizar el nombre completo antes de guardar
            datosPersona.NombreCompleto = $"{datosPersona.Nombre} {datosPersona.ApellidoPaterno} {datosPersona.ApellidoMaterno ?? ""}".Trim();

            // Actualizar el teléfono con el prefijo
            ActualizarTelefono();

            // Crear objeto de venta
            VentaDTO venta = new VentaDTO
                {
                    IdPersona = datosPersona.IdPersona,
                    Total = total,
                    MetodoEnvio = metodoEnvio,
                    MetodoPago = metodoPago,
                    DireccionEnvio = metodoEnvio == "delivery" ?
                        $"{direccionEnvio.DireccionCompleta}, {direccionEnvio.Ciudad}" :
                        "Recojo en tienda",
                    DetalleVenta = detalle
                };

            // Registrar la venta
            var response = await ventaServicio.Registrar(venta);

            if (response.EsCorrecto)
            {
                // Limpiar carrito después de la compra
                await carritoServicio.LimpiarCarrito();

                // Mostrar mensaje de éxito
                toastService.ShowSuccess("¡Compra realizada con éxito!");

                // Redirigir a la página de confirmación o catálogo
                _navServicio.NavigateTo("/catalogo");
            }
            else
            {
                toastService.ShowError(response.Mensaje ?? "Error al procesar la compra");
            }
        }
        catch (Exception ex)
        {
            toastService.ShowError($"Error al procesar la compra: {ex.Message}");
        }
    }

    // Clase auxiliar para los datos de dirección
    private class DireccionEnvio
    {
        public string Ciudad { get; set; } = "";
        public string DireccionCompleta { get; set; } = "";
    }
}