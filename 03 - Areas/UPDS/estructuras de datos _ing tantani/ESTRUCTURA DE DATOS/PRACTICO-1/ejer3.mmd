flowchart TD
    A[Inicio] --> B[int n = 1537]
    B --> C[Llamar estaOrdenado n]
    
    %% Función estaOrdenado
    C --> D[n = Math.abs n]
    D --> E{n < 10?}
    
    %% Caso base: un solo dígito
    E -->|Verdadero| F[return true]
    
    %% Caso recursivo: más de un dígito
    E -->|Falso| G[ultimo = n % 10]
    G --> H[penultimo = n / 10 % 10]
    H --> I{penultimo > ultimo?}
    
    %% Si no está ordenado
    I -->|Verdadero| J[return false]
    
    %% Si está ordenado, continuar recursión
    I -->|Falso| K[return estaOrdenado n / 10]
    K --> D
    
    %% Resultados finales
    F --> L[Resultado: true/false]
    J --> L
    L --> M[Imprimir resultado]
    M --> N[Fin]
    
  classDef startEnd fill:#000000,stroke:#01579b,stroke-width:2px
    classDef process fill:#000000,stroke:#4a148c,stroke-width:2px
    classDef decision fill:#000000,stroke:#e65100,stroke-width:2px
    classDef result fill:#000000,stroke:#2e7d32,stroke-width:2px
    
    class A,N startEnd
    class B,C,D,G,H,K,M process
    class E,I decision
    class F,J,L result
    