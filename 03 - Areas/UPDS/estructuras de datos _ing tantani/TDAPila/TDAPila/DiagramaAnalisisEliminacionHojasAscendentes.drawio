    <diagram name="Análisis Hojas Ascendentes" id="analisis-hojas-asc">
        <mxGraphModel dx="680" dy="646" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2000" math="0" shadow="0">
