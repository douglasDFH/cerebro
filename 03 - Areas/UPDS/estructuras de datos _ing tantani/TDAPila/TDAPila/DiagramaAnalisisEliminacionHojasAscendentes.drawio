                <mxCell id="algoritmo-titulo" value="ALGORITMO eliminarHojasAscendentes() - PASO A PASO" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="40" y="380" width="760" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="algo-codigo" value="public int eliminarHojasAscendentes() {&#xa;    if (raiz == null) {&#xa;        return 0;  // Árbol vacío&#xa;    }&#xa;    int[] contador = {0};&#xa;    raiz = eliminarHojasAscendentes(raiz, contador);&#xa;    return contador[0];&#xa;}&#xa;&#xa;private nodoAB eliminarHojasAscendentes(nodoAB nodo, int[] contador) {&#xa;    if (nodo == null) return null;&#xa;    &#xa;    // 1. Procesar recursivamente hijos&#xa;    nodo.setHijoI(eliminarHojasAscendentes(nodo.getHijoI(), contador));&#xa;    nodo.setHijoD(eliminarHojasAscendentes(nodo.getHijoD(), contador));&#xa;    &#xa;    // 2. Verificar si es hoja&#xa;    boolean esHoja = (nodo.getHijoI() == null &amp;&amp; nodo.getHijoD() == null);&#xa;    &#xa;    // 3. Si es hoja y valor ascendente, eliminar&#xa;    if (esHoja) {&#xa;        if (esValorAscendente((int) nodo.getDato())) {&#xa;            contador[0]++;&#xa;            return null;  // Eliminar hoja&#xa;        }&#xa;    }&#xa;    &#xa;    return nodo;  // Mantener nodo&#xa;}" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
                    <mxGeometry x="40" y="425" width="500" height="410" as="geometry"/>
                </mxCell>
                <mxCell id="proceso-titulo" value="PROCESO:" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="560" y="425" width="100" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="proc1" value="1. Recorre el árbol en post-orden" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11" vertex="1" parent="1">
                    <mxGeometry x="560" y="450" width="240" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="proc2" value="2. Primero procesa hijos (recursión)" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11" vertex="1" parent="1">
                    <mxGeometry x="560" y="490" width="240" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="proc3" value="3. Luego verifica si es hoja" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11" vertex="1" parent="1">
                    <mxGeometry x="560" y="530" width="240" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="proc4" value="4. Si es hoja ascendente → elimina" style="text;html=1;strokeColor=#d5e8d4;fillColor=#82b366;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=1;fontColor=#FFFFFF" vertex="1" parent="1">
                    <mxGeometry x="560" y="570" width="240" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="proc5" value="5. Si NO es hoja → mantiene" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11" vertex="1" parent="1">
                    <mxGeometry x="560" y="610" width="240" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="proc6" value="6. Retorna contador de eliminados" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11" vertex="1" parent="1">
                    <mxGeometry x="560" y="650" width="240" height="30" as="geometry"/>
                </mxCell>
