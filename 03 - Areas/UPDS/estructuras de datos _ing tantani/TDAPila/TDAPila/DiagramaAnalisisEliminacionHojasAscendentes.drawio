                <mxCell id="titulo" value="ANÁLISIS VISUAL DEL MÉTODO eliminarHojasAscendentes()" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="150" y="20" width="1300" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="concepto-titulo" value="CONCEPTO: ¿Qué es un Valor Ascendente?" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="40" y="80" width="760" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="concepto-def" value="Un valor ascendente es aquel cuyos dígitos están en orden estrictamente creciente.&#xa;Cada dígito debe ser MENOR que el siguiente.&#xa;&#xa;Ejemplos:&#xa;• 5 → UN SOLO DÍGITO → SÍ es ascendente&#xa;• 123 → 1 &lt; 2 &lt; 3 → SÍ es ascendente&#xa;• 145 → 1 &lt; 4 &lt; 5 → SÍ es ascendente&#xa;• 2345 → 2 &lt; 3 &lt; 4 &lt; 5 → SÍ es ascendente&#xa;• 312 → 3 &gt; 1 → NO es ascendente&#xa;• 555 → 5 = 5 (dígitos iguales) → NO es ascendente&#xa;• 54 → 5 &gt; 4 (descendente) → NO es ascendente" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="40" y="125" width="380" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="metodo-titulo" value="MÉTODO esValorAscendente():" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1" vertex="1" parent="1">
                    <mxGeometry x="440" y="125" width="200" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="metodo-codigo" value="private boolean esValorAscendente(int valor) {&#xa;    String numStr = String.valueOf(Math.abs(valor));&#xa;    &#xa;    // Un solo dígito es ascendente&#xa;    if (numStr.length() &lt;= 1) {&#xa;        return true;&#xa;    }&#xa;    &#xa;    // Verificar cada dígito &lt; siguiente&#xa;    for (int i = 0; i &lt; numStr.length() - 1; i++) {&#xa;        if (numStr.charAt(i) &gt;= numStr.charAt(i + 1)) {&#xa;            return false;&#xa;        }&#xa;    }&#xa;    &#xa;    return true;&#xa;}" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
                    <mxGeometry x="440" y="150" width="360" height="195" as="geometry"/>
                </mxCell>
