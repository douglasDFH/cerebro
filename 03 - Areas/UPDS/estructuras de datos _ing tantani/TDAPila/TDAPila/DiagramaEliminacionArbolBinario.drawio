                <mxCell id="algo-paso4a" value="   a) Encontrar sucesor in-orden (mínimo del subárbol derecho)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="370" y="630" width="400" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso4b" value="   b) Copiar el dato del sucesor al nodo actual" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="370" y="655" width="400" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso4c" value="   c) Eliminar recursivamente el sucesor del subárbol derecho" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="370" y="680" width="400" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="complejidad" value="Complejidad: O(h) donde h es la altura del árbol&#xa;En el peor caso (árbol degenerado): O(n)&#xa;En un árbol balanceado: O(log n)" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="800" y="515" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="nota-educativa" value="NOTA EDUCATIVA:&#xa;El sucesor in-orden es el nodo con el menor valor&#xa;en el subárbol derecho. Se encuentra yendo siempre&#xa;a la izquierda desde el hijo derecho del nodo a eliminar." style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="800" y="595" width="320" height="80" as="geometry"/>
