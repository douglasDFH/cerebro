                <!-- ALGORITMO -->
                <mxCell id="algo-titulo" value="ALGORITMO DE INSERCIÓN" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="40" y="750" width="600" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso1" value="1. Si el árbol está vacío → crear nuevo nodo como raíz" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="50" y="800" width="420" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso2" value="2. Si dato ≤ dato_actual → insertar en subárbol izquierdo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="50" y="830" width="420" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso3" value="3. Si dato &gt; dato_actual → insertar en subárbol derecho" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="50" y="860" width="420" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso4" value="4. Si hijo izquierdo/derecho es null → crear nuevo nodo allí" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="50" y="890" width="420" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="algo-paso5" value="5. Sino → continuar recursivamente en ese hijo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="50" y="920" width="420" height="25" as="geometry"/>
                </mxCell>

                <!-- COMPLEJIDAD -->
                <mxCell id="complejidad" value="COMPLEJIDAD TEMPORAL:&#xa;• Mejor caso: O(1) - insertar en raíz vacía&#xa;• Caso promedio: O(log n) - árbol balanceado&#xa;• Peor caso: O(n) - árbol degenerado (lista)" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="700" y="750" width="360" height="90" as="geometry"/>
                </mxCell>

                <!-- PROPIEDADES -->
                <mxCell id="propiedades" value="PROPIEDADES DEL ÁRBOL BINARIO DE BÚSQUEDA:&#xa;• Todos los nodos del subárbol izquierdo son menores&#xa;• Todos los nodos del subárbol derecho son mayores&#xa;• Permite búsqueda, inserción y eliminación eficientes&#xa;• El orden de inserción afecta la forma del árbol" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="700" y="860" width="360" height="100" as="geometry"/>
                </mxCell>

