        <mxCell id="PMNzZBzFdVE-wNSJf458-127" value="// En Orden&#xa;public void EnOrden() { EnOrden(raiz); }&#xa;private void EnOrden(nodoAB r) {&#xa;  if(r != null) {&#xa;    EnOrden(r.getHijoI()); // Izq&#xa;    System.out.println(r.getDato()); // Raíz&#xa;    EnOrden(r.getHijoD()); // Der&#xa;  }&#xa;}" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontFamily=Courier New;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
