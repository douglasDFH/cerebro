        <mxCell id="n4JkQlBb5BFMjF08qaKM-115" value="2. Si es nodo hoja → return null" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="570" y="1525" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-116" value="3. Si tiene un hijo → return ese hijo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="570" y="1550" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-117" value="4. Si tiene dos hijos:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="1575" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-118" value="   a) Encontrar sucesor (mínimo del subárbol derecho)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="580" y="1595" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-119" value="   b) Copiar dato del sucesor al nodo actual" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="580" y="1615" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-120" value="   c) Eliminar recursivamente el sucesor del subárbol der" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="580" y="1635" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-121" value="PUNTOS CLAVE" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1110" y="1460" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-122" value="• El método retorna una referencia al nodo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1120" y="1500" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-123" value="• La raíz puede cambiar (si se elimina)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1120" y="1525" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-124" value="• El sucesor in-orden mantiene BST" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1120" y="1550" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-125" value="• obtenerMinimo() va siempre a la izq" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1120" y="1575" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-126" value="• El caso 3 combina copia + eliminación" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1120" y="1600" width="280" height="20" as="geometry" />
        </mxCell>
        <mxCell id="n4JkQlBb5BFMjF08qaKM-127" value="• Las referencias se actualizan en la pila" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1120" y="1625" width="280" height="20" as="geometry" />
