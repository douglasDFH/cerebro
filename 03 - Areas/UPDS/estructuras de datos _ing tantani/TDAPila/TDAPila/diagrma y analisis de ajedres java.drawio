        <mxCell id="n4JkQlBb5BFMjF08qaKM-44" value="// Llamada&#xa;eliminarAB(70);&#xa;&#xa;// 1. Navegación: 70 &gt; 50 → der&#xa;// 2. Llega a nodo 70&#xa;// 3. Verifica hijos:&#xa;//    HijoI == null → true&#xa;//    HijoD != null (80)&#xa;// 4. return raizA.getHijoD()&#xa;//    (retorna referencia a 80)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
