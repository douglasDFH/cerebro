        <mxCell id="n4JkQlBb5BFMjF08qaKM-23" value="// Llamada&#xa;eliminarAB(35);&#xa;&#xa;// 1. raiz = eliminarAB(raiz, 35)&#xa;// 2. Navegación:&#xa;//    35 &lt; 50 → izq&#xa;//    35 &gt; 30 → der&#xa;//    35 &lt; 40 → izq&#xa;// 3. Llega a nodo 35&#xa;// 4. Verifica: HijoI==null &amp;&amp; HijoD==null&#xa;// 5. return null (elimina el nodo)" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
