        <mxCell id="zWLRPo1o5YdbHDy3sFA4-111" value="CONCEPTOS CLAVE DEL ALGORITMO" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="600" y="1360" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-112" value="• raiz: Referencia global al nodo raíz del árbol" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="610" y="1400" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-113" value="• raizA: Parámetro que apunta al nodo actual en recursión" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="610" y="1425" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-114" value="• nAux: Referencia al nuevo nodo a insertar" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="610" y="1450" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-115" value="• HijoI: Referencia al hijo izquierdo (≤)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="610" y="1475" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-116" value="• HijoD: Referencia al hijo derecho (&gt;)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="610" y="1500" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-117" value="• null: Indica que no hay referencia (fin de rama)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="610" y="1525" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-118" value="FLUJO DE RECURSIÓN" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1070" y="1360" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-119" value="1. Se compara nAux.getDato() con raizA.getDato()" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1080" y="1400" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-120" value="2. Si ≤ → navegar a HijoI, si &gt; → navegar a HijoD" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1080" y="1425" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="zWLRPo1o5YdbHDy3sFA4-121" value="3. Si el hijo es null → asignar nAux (caso base)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
