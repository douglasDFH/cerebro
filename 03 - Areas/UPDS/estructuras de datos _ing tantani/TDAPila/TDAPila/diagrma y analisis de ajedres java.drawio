        <mxCell id="zWLRPo1o5YdbHDy3sFA4-122" value="4. Si el hijo != null → llamada recursiva" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
