        <mxCell id="zWLRPo1o5YdbHDy3sFA4-123" value="5. La pila se desapila cuando termina la recursión" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
