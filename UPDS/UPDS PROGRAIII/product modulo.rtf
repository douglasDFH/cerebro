\par
function validateProductForm() \{\par
    const requiredFields = [\par
        \{field: '#name', message: 'El nombre es requerido'\},\par
        \{field: '#sku', message: 'El SKU es requerido'\},\par
        \{field: '#price', message: 'El precio es requerido'\},\par
        \{field: '#stock', message: 'El stock es requerido'\}\par
    ];\par
    \par
    let isValid = true;\par
    \par
    // Limpiar errores anteriores\par
    $('.is-invalid').removeClass('is-invalid');\par
    $('.invalid-feedback').remove();\par
    \par
    requiredFields.forEach(function(item) \{\par
        const field = $(item.field);\par
        const value = field.val().trim();\par
        \par
        if (!value) \{\par
            field.addClass('is-invalid');\par
            field.after(`<div class="invalid-feedback">$\{item.message\}</div>`);\par
            isValid = false;\par
        \}\par
    \});\par
    \par
    // Validaci\'f3n de n\'fameros\par
    const numericFields = ['#price', '#sale_price', '#stock', '#weight'];\par
    numericFields.forEach(function(fieldId) \{\par
        const field = $(fieldId);\par
        const value = field.val();\par
        \par
        if (value && (isNaN(value) || parseFloat(value) < 0)) \{\par
            field.addClass('is-invalid');\par
            field.after('<div class="invalid-feedback">Debe ser un n\'famero v\'e1lido mayor o igual a 0</div>');\par
            isValid = false;\par
        \}\par
    \});\par
    \par
    // Validaci\'f3n de precio de oferta\par
    const price = parseFloat($('#price').val());\par
    const salePrice = parseFloat($('#sale_price').val());\par
    \par
    if (salePrice && salePrice >= price) \{\par
        $('#sale_price').addClass('is-invalid');\par
        $('#sale_price').after('<div class="invalid-feedback">El precio de oferta debe ser menor al precio regular</div>');\par
        isValid = false;\par
    \}\par
    \par
    if (!isValid) \{\par
        // Scroll al primer error\par
        const firstError = $('.is-invalid').first();\par
        if (firstError.length) \{\par
            firstError[0].scrollIntoView(\{behavior: 'smooth', block: 'center'\});\par
        \}\par
    \}\par
    \par
    return isValid;\par
\}\par
\par
function populateProductForm(product) \{\par
    $('#product_id').val(product.id);\par
    $('#name').val(product.name || '');\par
    $('#short_description').val(product.short_description || '');\par
    $('#description').val(product.description || '');\par
    $('#price').val(product.price || '');\par
    $('#sale_price').val(product.sale_price || '');\par
    $('#sku').val(product.sku || '');\par
    $('#stock').val(product.stock || '');\par
    $('#min_stock').val(product.min_stock || '');\par
    $('#category_id').val(product.category_id || '');\par
    $('#brand_id').val(product.brand_id || '');\par
    $('#status').val(product.status || 'active');\par
    $('#featured').prop('checked', product.featured === true || product.featured === 1);\par
    $('#digital').prop('checked', product.digital === true || product.digital === 1);\par
    $('#manage_stock').prop('checked', product.manage_stock === true || product.manage_stock === 1);\par
    $('#specifications').val(product.specifications || '');\par
    $('#dimensions').val(product.dimensions || '');\par
    $('#weight').val(product.weight || '');\par
    $('#meta_title').val(product.meta_title || '');\par
    $('#meta_description').val(product.meta_description || '');\par
    $('#tags').val(product.tags || '');\par
    \par
    // Preview de imagen\par
    if (product.image) \{\par
        const imageUrl = window.ADMIN_CONFIG.base_url + 'public/assets/uploads/' + product.image;\par
        $('#imagePreview').html(`<img src="$\{imageUrl\}" class="img-fluid rounded" style="max-height: 150px;">`);\par
    \}\par
\}\par
