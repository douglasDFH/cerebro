function resetProductForm() \{\par
    $('#productForm')[0].reset();\par
    $('#product_id').val('');\par
    $('#imagePreview').empty();\par
    $('#productModal .modal-title').text('Nuevo Producto');\par
    \par
    // Limpiar errores\par
    $('.is-invalid').removeClass('is-invalid');\par
    $('.invalid-feedback').remove();\par
    \par
    console.log('\f3\u-10179?\u-8956?\f2  \f0 Formulario reseteado');\par
\}\par
\par
function handleImagePreview(input) \{\par
    const file = input.files[0];\par
    const preview = $('#imagePreview');\par
    \par
    if (file) \{\par
        // Validaciones\par
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];\par
        if (!allowedTypes.includes(file.type)) \{\par
            showAdminNotification('Solo se permiten im\'e1genes JPG, PNG, GIF o WebP', 'error');\par
            $(input).val('');\par
            preview.empty();\par
            return;\par
        \}\par
        \par
        if (file.size > 5 * 1024 * 1024) \{\par
            showAdminNotification('La imagen no puede ser mayor a 5MB', 'error');\par
            $(input).val('');\par
            preview.empty();\par
            return;\par
        \}\par
        \par
        // Mostrar preview\par
        const reader = new FileReader();\par
        reader.onload = function(e) \{\par
            preview.html(`\par
                <img src="$\{e.target.result\}" class="img-fluid rounded shadow" style="max-height: 150px;">\par
                <div class="mt-2 text-muted small">\par
                    <i class="fas fa-file-image me-1"></i>\par
                    $\{file.name\} ($\{(file.size / 1024 / 1024).toFixed(2)\} MB)\par
                </div>\par
            `);\par
        \};\par
        reader.readAsDataURL(file);\par
    \} else \{\par
        preview.empty();\par
    \}\par
\}\par
\par
function handleFormErrors(response) \{\par
    if (response && response.errors) \{\par
        // Mostrar errores de validaci\'f3n\par
        for (const field in response.errors) \{\par
            const input = $('#' + field);\par
            if (input.length) \{\par
                input.addClass('is-invalid');\par
                \par
                let errorMessage = response.errors[field];\par
                if (Array.isArray(errorMessage)) \{\par
                    errorMessage = errorMessage[0];\par
                \}\par
                \par
                input.after(`<div class="invalid-feedback">$\{errorMessage\}</div>`);\par
            \}\par
        \}\par
        \par
        // Scroll al primer error\par
        const firstError = $('.is-invalid').first();\par
        if (firstError.length) \{\par
            firstError[0].scrollIntoView(\{behavior: 'smooth', block: 'center'\});\par
        \}\par
    \}\par
    \par
    const message = response?.message || 'Error en el formulario';\par
    showAdminNotification(message, 'error');\par
\}\par
\par
function generateSKU(name) \{\par
    const cleanName = name.toLowerCase()\par
        .replace(/[\'e1\'e9\'ed\'f3\'fa\'f1\'fc]/g, function(match) \{\par
            const map = \{\'e1:'a',\'e9:'e',\'ed:'i',\'f3:'o',\'fa:'u',\'f1:'n',\'fc:'u'\};\par
            return map[match];\par
        \})\par
        .replace(/[^a-z0-9\\s-]/g, '')\par
        .replace(/\\s+/g, '-')\par
        .replace(/-+/g, '-')\par
        .replace(/^-|-$/g, '');\par
    \par
    const timestamp = Date.now().toString().slice(-4);\par
    return 'PRD-' + cleanName.substring(0, 8).toUpperCase() + '-' + timestamp;\par
\}\par
