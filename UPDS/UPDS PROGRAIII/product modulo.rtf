<script>\par
// =====================================================\par
// JAVASCRIPT PARA GESTI\'d3N DE PRODUCTOS - ADMINISTRADOR\par
// =====================================================\par
\par
// \f1\u9989?\f2  \f0 CONFIGURACI\'d3N GLOBAL\par
window.ADMIN_CONFIG = \{\par
    base_url: '<?php echo $base_url; ?>',\par
    currency_symbol: '<?php echo $currency_symbol; ?>',\par
    store_name: '<?php echo $store_name; ?>'\par
\};\par
\par
// \f1\u9989?\f2  \f0 INICIALIZACI\'d3N AL CARGAR DOM\par
$(document).ready(function() \{\par
    console.log('\f3\u-10179?\u-8576?\f2  \f0 Iniciando gesti\'f3n de productos...');\par
    console.log('\f3\u-10179?\u-9011?\f2  \f0 Base URL:', window.ADMIN_CONFIG.base_url);\par
    \par
    // Inicializar DataTable\par
    initializeDataTable();\par
    \par
    // Configurar formulario de productos\par
    setupProductForm();\par
    \par
    // Configurar filtros\par
    setupFilters();\par
    \par
    // Configurar subida de im\'e1genes\par
    setupImageUpload();\par
    \par
    // Event listeners\par
    attachEventListeners();\par
    \par
    console.log('\f1\u9989?\f2  \f0 Gesti\'f3n de productos inicializada correctamente');\par
\});\par
\par
// =====================================================\par
// FUNCIONES DE INICIALIZACI\'d3N\par
// =====================================================\par
\par
function initializeDataTable() \{\par
    if ($('#productsTable').length === 0) return;\par
    \par
    try \{\par
        const table = $('#productsTable').DataTable(\{\par
            pageLength: 25,\par
            order: [[0, 'desc']],\par
            language: \{\par
                url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/es-ES.json'\par
            \},\par
            columnDefs: [\par
                \{ orderable: false, targets: -1 \}, // Columna de acciones\par
                \{ className: 'text-center', targets: [0, 6, 7, 8] \} // Centrar ciertas columnas\par
            ],\par
            responsive: true,\par
            dom: '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>rtip',\par
            initComplete: function() \{\par
                console.log('\f1\u9989?\f2  \f0 DataTable inicializada');\par
            \}\par
        \});\par
        \par
        // Configurar filtros personalizados\par
        $('#searchFilter').on('keyup', function() \{\par
            table.search(this.value).draw();\par
        \});\par
        \par
        $('#categoryFilter').on('change', function() \{\par
            table.column(4).search(this.value).draw();\par
        \});\par
        \par
        $('#statusFilter').on('change', function() \{\par
            table.column(7).search(this.value).draw();\par
        \});\par
        \par
        // Guardar referencia global\par
        window.productsTable = table;\par
        \par
    \} catch (error) \{\par
        console.error('\f1\u10060?\f2  \f0 Error inicializando DataTable:', error);\par
        showAdminNotification('Error al cargar la tabla de productos', 'error');\par
    \}\par
\}\par
\par
function setupProductForm() \{\par
    const form = $('#productForm');\par
    if (form.length === 0) return;\par
    \par
    // Prevenir env\'edo normal del formulario\par
    form.on('submit', function(e) \{\par
        e.preventDefault();\par
        e.stopPropagation();\par
        handleProductSubmit();\par
        return false;\par
    \});\par
    \par
    // Auto-generar SKU basado en el nombre\par
    $('#name').on('input', debounce(function() \{\par
        const name = $(this).val();\par
        const isNewProduct = !$('#product_id').val();\par
        \par
        if (name && isNewProduct && !$('#sku').val()) \{\par
            const sku = generateSKU(name);\par
            $('#sku').val(sku);\par
        \}\par
    \}, 500));\par
    \par
    // Validaci\'f3n de precio de oferta\par
    $('#sale_price').on('input', function() \{\par
        const salePrice = parseFloat($(this).val());\par
        const regularPrice = parseFloat($('#price').val());\par
        \par
        if (salePrice && regularPrice && salePrice >= regularPrice) \{\par
            $(this).addClass('is-invalid');\par
            $(this).siblings('.invalid-feedback').remove();\par
            $(this).after('<div class="invalid-feedback">El precio de oferta debe ser menor al precio regular</div>');\par
        \} else \{\par
            $(this).removeClass('is-invalid');\par
            $(this).siblings('.invalid-feedback').remove();\par
        \}\par
    \});\par
    \par
    console.log('\f1\u9989?\f2  \f0 Formulario de productos configurado');\par
\}\par
\par
function setupFilters() \{\par
    // Reset de filtros\par
    $('#clearFiltersBtn').on('click', function() \{\par
        clearAllFilters();\par
    \});\par
    \par
    // Aplicar filtros en tiempo real\par
    const filterInputs = $('#searchFilter, #categoryFilter, #statusFilter');\par
    filterInputs.on('change keyup', debounce(function() \{\par
        applyFilters();\par
    \}, 300));\par
    \par
    console.log('\f1\u9989?\f2  \f0 Filtros configurados');\par
\}\par
\par
function setupImageUpload() \{\par
    $('#image').on('change', function() \{\par
        handleImagePreview(this);\par
    \});\par
    \par
    // Drag & Drop (opcional)\par
    const dropZone = $('.image-drop-zone');\par
    if (dropZone.length > 0) \{\par
        setupDragDrop(dropZone);\par
    \}\par
    \par
    console.log('\f1\u9989?\f2  \f0 Sistema de im\'e1genes configurado');\par
\}\par
\par
function attachEventListeners() \{\par
    // Modal events\par
    $('#productModal').on('hidden.bs.modal', function() \{\par
        resetProductForm();\par
    \});\par
    \par
    $('#productModal').on('shown.bs.modal', function() \{\par
        $('#name').focus();\par
    \});\par
    \par
    // Keyboard shortcuts\par
    $(document).on('keydown', function(e) \{\par
        // Ctrl/Cmd + N = Nuevo producto\par
        if ((e.ctrlKey || e.metaKey) && e.key === 'n' && !$('.modal').hasClass('show')) \{\par
            e.preventDefault();\par
            $('#productModal').modal('show');\par
        \}\par
        \par
        // Escape = Cerrar modal\par
        if (e.key === 'Escape' && $('.modal').hasClass('show')) \{\par
            $('.modal').modal('hide');\par
        \}\par
    \});\par
    \par
    console.log('\f1\u9989?\f2  \f0 Event listeners configurados');\par
\}\par
