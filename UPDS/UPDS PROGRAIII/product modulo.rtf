// Utilidad: Debounce\par
function debounce(func, wait, immediate) \{\par
    let timeout;\par
    return function executedFunction(...args) \{\par
        const later = () => \{\par
            timeout = null;\par
            if (!immediate) func(...args);\par
        \};\par
        const callNow = immediate && !timeout;\par
        clearTimeout(timeout);\par
        timeout = setTimeout(later, wait);\par
        if (callNow) func(...args);\par
    \};\par
\}\par
