function handleProductSubmit() \{\par
    const form = $('#productForm')[0];\par
    const formData = new FormData(form);\par
    const submitBtn = $('#productForm button[type="submit"]');\par
    const originalText = submitBtn.html();\par
    \par
    // Validaciones b\'e1sicas\par
    if (!validateProductForm()) \{\par
        return false;\par
    \}\par
    \par
    // UI: Deshabilitar bot\'f3n\par
    submitBtn.prop('disabled', true)\par
             .html('<i class="fas fa-spinner fa-spin"></i> Guardando...');\par
    \par
    // Determinar acci\'f3n\par
    const action = $('#product_id').val() ? 'update' : 'create';\par
    formData.set('action', action);\par
    \par
    console.log('\f3\u-10179?\u-8988?\f2  \f0 Enviando producto...', action);\par
    \par
    $.ajax(\{\par
        url: window.ADMIN_CONFIG.base_url + 'admin/products/save',\par
        method: 'POST',\par
        data: formData,\par
        processData: false,\par
        contentType: false,\par
        dataType: 'json',\par
        timeout: 30000,\par
        success: function(response) \{\par
            console.log('\f1\u9989?\f2  \f0 Respuesta:', response);\par
            \par
            if (response && response.success) \{\par
                showAdminNotification(response.message || 'Producto guardado exitosamente', 'success');\par
                $('#productModal').modal('hide');\par
                \par
                // Recargar tabla o p\'e1gina\par
                if (window.productsTable) \{\par
                    window.productsTable.ajax.reload();\par
                \} else \{\par
                    setTimeout(() => location.reload(), 1500);\par
                \}\par
            \} else \{\par
                handleFormErrors(response);\par
            \}\par
        \},\par
        error: function(xhr, status, error) \{\par
            console.error('\f1\u10060?\f2  \f0 Error AJAX:', \{xhr, status, error\});\par
            \par
            let errorMessage = 'Error de conexi\'f3n';\par
            \par
            if (xhr.status === 404) \{\par
                errorMessage = 'Ruta no encontrada. Verifica la configuraci\'f3n.';\par
            \} else if (xhr.status === 500) \{\par
                errorMessage = 'Error interno del servidor. Revisa los logs.';\par
            \} else if (xhr.responseJSON?.message) \{\par
                errorMessage = xhr.responseJSON.message;\par
            \}\par
            \par
            showAdminNotification(errorMessage, 'error');\par
        \},\par
        complete: function() \{\par
            // Rehabilitar bot\'f3n\par
            submitBtn.prop('disabled', false).html(originalText);\par
        \}\par
    \});\par
\}\par
