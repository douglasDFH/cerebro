flowchart TD
    A[Inicio] --> B[int n = 5]
    B --> C[Llamar sumatoria n]
    
    %% Función sumatoria
    C --> D[Función sumatoria n]
    D --> E{n <= 0?}
    
    %% Caso base
    E -->|Verdadero| F[return 0]
    
    %% Caso recursivo
    E -->|Falso| G[return n + sumatoria n - 1]
    G --> D
    
    %% Resultado final
    F --> H[Resultado obtenido]
    
    %% Procesamiento de resultado en main
    H --> I[Imprimir: 'La sumatoria de n es: resultado']
    I --> J[Fin]
    
    %% Ejemplo de ejecución con n=5
    K[Ejemplo: n=5] --> L[5 + sumatoria 4]
    L --> M[4 + sumatoria 3]
    M --> N[3 + sumatoria 2]
    N --> O[2 + sumatoria 1]
    O --> P[1 + sumatoria 0]
    P --> Q[sumatoria 0 = 0]
    Q --> R[Resultado: 5+4+3+2+1+0 = 15]
    
    %% Estilos
    classDef startEnd fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#000000
    classDef process fill:#f3e5f5,stroke:#4a148c,stroke-width:2px,color:#000000
    classDef decision fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#000000
    classDef result fill:#e8f5e8,stroke:#2e7d32,stroke-width:2px,color:#000000
    classDef recursion fill:#fff9c4,stroke:#f57f17,stroke-width:2px,color:#000000
    classDef example fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#000000
    
    class A,J startEnd
    class B,C,D,I process
    class E decision
    class F,H,R result
    class G recursion
    class K,L,M,N,O,P,Q example
    
    %% Estilos para flechas blancas
    linkStyle default stroke:#ffffff,stroke-width:2px