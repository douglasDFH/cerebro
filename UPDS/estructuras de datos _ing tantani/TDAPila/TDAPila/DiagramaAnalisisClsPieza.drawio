                <mxCell id="simb-codigo" value="public String getSimbolo() {&#xa;    String simbolo = &quot;&quot;;&#xa;    switch(tipo) {&#xa;        case &quot;REY&quot;:&#xa;            simbolo = color.equals(&quot;BLANCO&quot;) ? &quot;♔&quot; : &quot;♚&quot;;&#xa;            break;&#xa;        case &quot;REINA&quot;:&#xa;            simbolo = color.equals(&quot;BLANCO&quot;) ? &quot;♕&quot; : &quot;♛&quot;;&#xa;            break;&#xa;        // ... más casos&#xa;    }&#xa;    return simbolo;&#xa;}" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" parent="1" vertex="1">
