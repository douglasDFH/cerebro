                <mxCell id="simb-paso2-switch" value="switch(tipo) {&#xa;  case &quot;REY&quot;: ✓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontFamily=Courier New;align=left;" parent="1" vertex="1">
