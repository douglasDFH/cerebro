                <mxCell id="flujo-step3" value="3. VALIDAR MOV" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="560" y="2220" width="200" height="40" as="geometry"/>
