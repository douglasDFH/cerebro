                <mxCell id="vent1" value="✓ REUTILIZACIÓN: caminoLibre() usado por Torre, Alfil, Reina" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="80" y="2410" width="600" height="30" as="geometry"/>
