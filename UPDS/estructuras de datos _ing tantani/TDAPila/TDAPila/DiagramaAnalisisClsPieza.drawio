                <mxCell id="flujo-arrow3" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666666;endArrow=classic;endFill=1;" parent="1" source="flujo-step3" target="flujo-step4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <mxCell id="flujo-step4" value="4. ACTUALIZAR POS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="800" y="2220" width="200" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="flujo-step4-code" value="if(valido) {&#xa;  rey.setColumna(5);&#xa;  rey.setSeHaMovido(true);&#xa;}" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" parent="1" vertex="1">
