                <mxCell id="flujo-step3-code" value="boolean valido = &#xa;rey.esMovimientoValido(&#xa;  0, 5, tablero);" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" parent="1" vertex="1">
