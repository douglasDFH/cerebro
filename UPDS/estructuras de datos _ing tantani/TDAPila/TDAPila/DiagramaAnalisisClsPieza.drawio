                <mxCell id="res-abstract" value="CLASE ABSTRACTA" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="60" y="2010" width="400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="res-abstract-text" value="• No se puede instanciar directamente&#xa;• Define estructura común para todas las piezas&#xa;• Método abstracto: esMovimientoValido()&#xa;  - Cada subclase (Rey, Torre, etc.) debe&#xa;    implementarlo según sus reglas específicas" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="70" y="2050" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="res-encapsulacion" value="ENCAPSULACIÓN" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="500" y="2010" width="400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="res-encaps-text" value="• Atributos protected → acceso desde subclases&#xa;• Getters/Setters públicos → control de acceso&#xa;• caminoLibre() protected → método auxiliar&#xa;  reutilizable solo por clases hijas&#xa;• Validación centralizada del movimiento" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="510" y="2050" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="res-herencia" value="HERENCIA Y POLIMORFISMO" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="940" y="2010" width="400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="res-herencia-text" value="• Subclases: clsRey, clsReina, clsTorre, etc.&#xa;• Cada una implementa esMovimientoValido()&#xa;• Pueden usar caminoLibre() heredado&#xa;• getSimbolo() devuelve símbolo específico&#xa;  basado en tipo y color" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="950" y="2050" width="380" height="90" as="geometry"/>
                </mxCell>

                <mxCell id="res-flujo-titulo" value="FLUJO DE USO TÍPICO:" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="60" y="2170" width="1280" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="flujo-step1" value="1. CREAR PIEZA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="80" y="2220" width="200" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="flujo-step1-code" value="clsRey rey = new clsRey(&#xa;  &quot;BLANCO&quot;, 0, 4);" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="80" y="265" width="200" height="35" as="geometry"/>
                </mxCell>

                <mxCell id="flujo-arrow1" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666666;endArrow=classic;endFill=1;" parent="1" source="flujo-step1" target="flujo-step2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <mxCell id="flujo-step2" value="2. OBTENER INFO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="320" y="2220" width="200" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="flujo-step2-code" value="String s = rey.getSimbolo();&#xa;// s = &quot;♔&quot;" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="320" y="2265" width="200" height="35" as="geometry"/>
                </mxCell>

                <mxCell id="flujo-arrow2" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeWidth=2;strokeColor=#666666;endArrow=classic;endFill=1;" parent="1" source="flujo-step2" target="flujo-step3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
