                <!-- VENTAJAS DEL DISEÑO -->
                <mxCell id="ventajas-titulo" value="VENTAJAS DE ESTE DISEÑO TDA:" style="text;html=1;strokeColor=#a50040;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=15;fontStyle=1" parent="1" vertex="1">
