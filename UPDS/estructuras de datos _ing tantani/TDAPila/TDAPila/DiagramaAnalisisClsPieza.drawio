                <!-- SECCIÓN 6: RESUMEN Y CONCEPTOS -->
                <mxCell id="sec6-titulo" value="SECCIÓN 6: RESUMEN DE CONCEPTOS CLAVE" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=18;fontStyle=1" parent="1" vertex="1">
