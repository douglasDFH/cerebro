                <mxCell id="caso0-titulo" value="CASO 0: Validación Inicial - if(raiz == null) return false" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=16;fontStyle=1" vertex="1" parent="1">
