                <mxCell id="c3-codigo" value="// Llamada: eliminarAB(30);&#xa;&#xa;// 1. Navegación: 30 &lt; 50 → izq&#xa;// 2. Llega a nodo 30&#xa;// 3. Verifica: HijoI != null &amp;&amp; HijoD != null&#xa;// 4. Buscar sucesor in-orden:&#xa;//    sucesor = obtenerMinimo(raizA.getHijoD())&#xa;//    - Empieza en 40&#xa;//    - Busca el más a la izquierda&#xa;//    - Encuentra 35&#xa;// 5. raizA.setDato(35)  // Copia el dato&#xa;// 6. Eliminar el nodo 35 original:&#xa;//    raizA.setHijoD(eliminarAB(raizA.getHijoD(), 35))" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;fontFamily=Courier New;" parent="1" vertex="1">
