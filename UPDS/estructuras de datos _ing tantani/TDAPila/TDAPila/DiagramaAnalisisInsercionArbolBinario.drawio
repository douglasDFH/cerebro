                </mxCell>
                <mxCell id="concepto1" value="• raiz: Referencia global al nodo raíz del árbol" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1240" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="concepto2" value="• raizA: Parámetro que apunta al nodo actual en recursión" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1265" width="450" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="concepto3" value="• nAux: Referencia al nuevo nodo a insertar" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1290" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="concepto4" value="• HijoI: Referencia al hijo izquierdo (≤)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1315" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="concepto5" value="• HijoD: Referencia al hijo derecho (&gt;)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1340" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="concepto6" value="• null: Indica que no hay referencia (fin de rama)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="360" y="1365" width="450" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="flujo-titulo" value="FLUJO DE RECURSIÓN" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="820" y="1200" width="300" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="flujo1" value="1. Se compara nAux.getDato() con raizA.getDato()" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="830" y="1240" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="flujo2" value="2. Si ≤ → navegar a HijoI, si &gt; → navegar a HijoD" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="830" y="1265" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="flujo3" value="3. Si el hijo es null → asignar nAux (caso base)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="830" y="1290" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="flujo4" value="4. Si el hijo != null → llamada recursiva" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="830" y="1315" width="380" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="flujo5" value="5. La pila se desapila cuando termina la recursión" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" parent="1" vertex="1">
                    <mxGeometry x="830" y="1340" width="380" height="20" as="geometry"/>
